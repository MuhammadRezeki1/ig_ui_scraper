# ============================================================================
# .env (root) — dipakai docker-compose.yml untuk build & deploy.
# Salin file ini jadi `.env` lalu sesuaikan:  cp .env.example .env
# Semua punya default aman di compose, jadi yang wajib diisi cuma bagian
# "DEPLOY / DOMAIN" saat naik ke server.
# ============================================================================

# ── Backend runtime ─────────────────────────────────────────────────────────
ENGINE_PATH=/app/engine
API_PORT=8000
API_HOST=0.0.0.0
HEADLESS=true
PROFILE_DIR=chrome_profile_playwright

# ── Sentiment / Gemini (opsional, default mati) ─────────────────────────────
GEMINI_ENABLED=False
GEMINI_API_KEY=
GEMINI_CONFIDENCE_THRESHOLD=0.70

# ── DEPLOY / DOMAIN (WAJIB diisi saat naik ke server) ───────────────────────
# URL publik backend yang diakses BROWSER. Di-bake saat `docker compose build`
# (lihat build.args frontend), jadi build ulang kalau ganti nilai ini.
# Lokal: http://localhost:8000  |  Server: https://api.domainmu.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL backend yang diakses Next.js server-side DI DALAM jaringan compose.
# Biarkan pakai nama service: http://backend:8000
INTERNAL_API_URL=http://backend:8000

# Origin yang diizinkan CORS di backend (pisah koma). "*" = semua.
CORS_ORIGINS=*

# ── Proxy (opsional, kosongkan kalau tidak pakai) ───────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=
